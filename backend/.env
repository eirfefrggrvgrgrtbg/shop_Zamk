APP_ENV=local
APP_PORT=8080
PUBLIC_BASE_URL=http://127.0.0.1:5173
API_BASE_URL=http://127.0.0.1:8080

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=zamk
POSTGRES_PASSWORD=zamk_password
POSTGRES_DB=zamk
POSTGRES_SSLMODE=disable
POSTGRES_DSN=postgres://zamk:zamk_password@127.0.0.1:5433/zamk?sslmode=disable

REDIS_HOST=127.0.0.1
REDIS_ADDR=127.0.0.1:6379
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

S3_ENDPOINT=localhost:9000
S3_BUCKET=zamk-products
S3_ACCESS_KEY=zamk_minio
S3_SECRET_KEY=zamk_minio_password
S3_USE_SSL=false

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:3002
